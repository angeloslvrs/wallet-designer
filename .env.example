# Cert profile selector — dev (default) or prod
CERT_PROFILE=dev

# Apple-issued in prod; arbitrary in dev
PASS_TYPE_ID=pass.dev.local
TEAM_ID=DEV0000000

# Organization shown on pass
ORG_NAME=Rocket Partners Airlines

# Server port
PORT=4317
VITE_PORT=4318

# Private key passphrase (optional)
# KEY_PASSPHRASE=
